{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dockit",
  "version": "0.1.0",
  "identifier": "com.ben.dockit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dockit",
        "width": 1480,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
